# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  copy to .env for local development, NEVER commit .env
# In Vercel: add each variable under Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Found in: https://platform.openai.com/api-keys
REACT_APP_OPENAI_API_KEY=sk-proj-...
